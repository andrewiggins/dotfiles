# Sourcing from variable paths (~/.extra, ~/.cargo/env)
disable=SC1090
# Source file not found (expected in CI where dependencies aren't installed)
disable=SC1091
# Variable appears unused — starship_precmd_user_func is read by starship
disable=SC2034
# Quote to prevent word splitting — intentional in terminal title setting
disable=SC2046
# Useless echo — used for pipe readability in terminal title setting
disable=SC2005
# Double quote to prevent globbing — info-level, upstream GitHub CLI install snippet
disable=SC2086
# Command appears unreachable — expected from chezmoi early-exit pattern (exit 0 on wrong OS)
disable=SC2317
